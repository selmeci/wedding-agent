{
  "name": "cloudflare-agent-starter",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "start": "vite dev",
    "build": "vite build",
    "deploy": "vite build && wrangler deploy",
    "test": "vitest",
    "cf:typegen": "wrangler types env.d.ts --include-runtime false",
    "format": "prettier --write .",
    "check": "prettier . --check && biome lint && tsc",
    "postinstall": "patch-package",
    "db:generate": "drizzle-kit generate --schema=./src/db/index.ts --out=./drizzle --dialect=sqlite",
    "db:migrate": "wrangler d1 migrations apply wedding-db",
    "db:migrate:remote": "wrangler d1 migrations apply wedding-db --remote"
  },
  "keywords": [
    "cloudflare",
    "ai",
    "agents"
  ],
  "author": "Roman Selmeci",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@cloudflare/vite-plugin": "1.19.0",
    "@cloudflare/vitest-pool-workers": "0.11.1",
    "@cloudflare/workers-types": "4.20251223.0",
    "@tailwindcss/vite": "4.1.18",
    "@types/node": "25.0.3",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.2",
    "drizzle-kit": "^0.31.8",
    "patch-package": "8.0.1",
    "prettier": "3.7.4",
    "tailwindcss": "4.1.18",
    "typescript": "5.9.3",
    "vite": "7.3.0",
    "vitest": "4.0.16",
    "wrangler": "4.56.0"
  },
  "dependencies": {
    "@ai-sdk/openai": "3.0.0",
    "@ai-sdk/react": "3.0.1",
    "@phosphor-icons/react": "2.1.10",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "agents": "0.3.0",
    "ai": "6.0.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.11.1",
    "marked": "17.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "streamdown": "1.6.10",
    "tailwind-merge": "3.4.0",
    "ts-pattern": "^5.9.0",
    "workers-ai-provider": "3.0.0"
  }
}
